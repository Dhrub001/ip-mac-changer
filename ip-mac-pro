    echo -e "${BOLD}${CYAN}[рҹҢҖ] CHANGE CYCLE #${COUNTER}${NC}"
    echo -e "${PURPLE}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${NC}"
    change_mac
    sleep 2
    change_ip
    echo ""
    echo -e "${BLUE}рҹ“Ў Current Status:${NC}"
    echo -e "   MAC: ${GREEN}$(cat /sys/class/net/$INTERFACE/address)${NC}"
