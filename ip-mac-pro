esac

echo ""
echo -e "${GREEN}[вң“] Interval: ${INTERVAL} seconds - ${MODE}${NC}"
echo -e "${YELLOW}[!] Press Ctrl+C to stop and restore original MAC${NC}"
echo ""

# Restore function
restore_mac() {
    echo -e "\n${YELLOW}[!] Restoring original MAC...${NC}"
    sudo ip link set dev $INTERFACE down 2>/dev/null
    sudo ip link set dev $INTERFACE address $ORIGINAL_MAC 2>/dev/null
    sudo ip link set dev $INTERFACE up 2>/dev/null
    echo -e "${GREEN}[вң“] Original MAC restored: $ORIGINAL_MAC${NC}"
    echo -e "${RED}[вң—] IP & MAC Changer stopped${NC}"
    exit 0
}
trap restore_mac SIGINT SIGTERM

# Change MAC function
change_mac() {
    NEW_MAC=$(printf "02:%02x:%02x:%02x:%02x:%02x" $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)))
    echo -e "${CYAN}[вҶ’] Changing MAC address...${NC}"
    sudo ip link set dev $INTERFACE down 2>/dev/null
    sudo ip link set dev $INTERFACE address $NEW_MAC 2>/dev/null
    sudo ip link set dev $INTERFACE up 2>/dev/null
    sleep 1
    if [ "$(cat /sys/class/net/$INTERFACE/address)" = "$NEW_MAC" ]; then
        echo -e "${GREEN}[вң“] MAC changed: ${NEW_MAC}${NC}"
        return 0
    else
        echo -e "${RED}[вң—] MAC change failed!${NC}"
        return 1
    fi
}

# Change IP function
change_ip() {
    echo -e "${CYAN}[вҶ’] Renewing IP address (DHCP)...${NC}"
    sudo dhclient -r $INTERFACE 2>/dev/null
    sleep 1
    sudo dhclient $INTERFACE 2>/dev/null
    sleep 2
    CURRENT_IP=$(ip -4 addr show $INTERFACE 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -1)
    if [ -n "$CURRENT_IP" ]; then
        echo -e "${GREEN}[вң“] New IP: ${CURRENT_IP}${NC}"
        return 0
    else
        echo -e "${YELLOW}[!] IP unchanged or no DHCP${NC}"
        return 1
    fi
}

# Main loop
COUNTER=0
while true; do
