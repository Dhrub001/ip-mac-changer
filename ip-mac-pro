# Detect interface
INTERFACE=$(ip route | grep default | awk '{print $5}' | head -1)
[ -z "$INTERFACE" ] && INTERFACE=$(ip link show | grep -v lo | grep "state UP" | head -1 | cut -d: -f2 | xargs)

ORIGINAL_MAC=$(cat /sys/class/net/$INTERFACE/address 2>/dev/null)

echo -e "${CYAN}[i] Interface: ${GREEN}$INTERFACE${NC}"
echo -e "${CYAN}[i] Original MAC: ${GREEN}$ORIGINAL_MAC${NC}"
echo ""

# Interval selection
echo -e "${YELLOW}в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${NC}"
