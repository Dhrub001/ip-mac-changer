    echo -e "   IP:  ${GREEN}${CURRENT_IP:-No IP assigned}${NC}"
    echo -e "\n${YELLOW}[вҸ°] Next change in ${INTERVAL} seconds...${NC}"
    sleep $INTERVAL
done
