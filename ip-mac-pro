read -p "$(echo -e ${CYAN}[?] Enter your choice [1-5]: ${NC})" CHOICE

case $CHOICE in
    1) INTERVAL=10; MODE="Movie Mode (10 seconds)" ;;
    2) INTERVAL=20; MODE="Turbo Mode (20 seconds)" ;;
    3) INTERVAL=30; MODE="Normal Mode (30 seconds)" ;;
