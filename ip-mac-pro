echo -e "${CYAN}    2) ${GREEN}20 seconds${NC}  - Turbo Mode"
echo -e "${CYAN}    3) ${GREEN}30 seconds${NC}  - Normal Mode ${YELLOW}(Recommended)${NC}"
echo -e "${CYAN}    4) ${GREEN}60 seconds${NC}  - Stealth Mode"
echo -e "${CYAN}    5) ${GREEN}Custom${NC}      - Enter your own value"
